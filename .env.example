# PayBack SA — Environment Variables
# Copy this file to .env and fill in your values

# RevenueCat API Keys (from RevenueCat dashboard)
REVENUCAT_ANDROID_API_KEY=goog_YOUR_ANDROID_KEY
REVENUCAT_IOS_API_KEY=appl_YOUR_IOS_KEY

# Sentry (from sentry.io project settings)
SENTRY_DSN=https://YOUR_DSN@sentry.io/PROJECT_ID

# Google Cloud Vision (for receipt OCR)
GOOGLE_CLOUD_VISION_API_KEY=YOUR_GOOGLE_CLOUD_VISION_KEY
